# ============================================
# .gitignore — Optimal Pension Reforms
# ============================================

# --- Vídeos e áudio (760MB+) ---
videos/
*.mp4
*.m4a
*.avi
*.mov
*.mkv

# --- Outputs gerados pelo pipeline ---
# (podem ser regenerados rodando o código no PC remoto)
trans_retirement/output/

# --- Functional-layout I/O (restructure; regeneratable / confidential — keep only .gitkeep) ---
build/output/*
!build/output/.gitkeep
build/temp/*
!build/temp/.gitkeep
build/input/*
!build/input/.gitkeep
analysis/output/*
!analysis/output/.gitkeep
analysis/temp/*
!analysis/temp/.gitkeep
analysis/input/*
!analysis/input/.gitkeep

# --- Golden-baseline heavy artifacts (keep the .md/.csv provenance, ignore the bulk) ---
quality_reports/baseline/figures_before/
quality_reports/baseline/figures_asis/
quality_reports/baseline/logs/
quality_reports/baseline/logs_stage3/

# --- Versões do paper e apresentações (PDFs binários) ---
paper/

# --- PDF de cálculos manuscritos ---
Cálculos Juan*.pdf

# --- Dados binários (Stata .dta) ---
*.dta

# --- Arquivos temporários do R ---
.Rhistory
.Rdata
.RData
*.Rproj.user/
.Rproj.user/
*.rds
*.RDS

# --- Arquivos temporários do Stata ---
*.log
*.smcl

# --- OS files ---
.DS_Store
Thumbs.db
desktop.ini

# --- Dados locais (5% sample — NEVER commit) ---
data_local/
*.csv.gz

# --- Arquivos temporários genéricos ---
*.tmp
*.bak
*~

# --- CLAUDE.md raiz ---
# CLAUDE.md is now tracked (project configuration for Claude Code)
# CLAUDE.md

# --- Arquivo interno do Claude/Cowork ---
_docs/zi4yABHg

# --- I7 diagnostic report + reference appendix (docs/outputs, not code) ---
_docs/I7_diagnostic_report.md
_docs/I7_diagnostic_report.pdf
_docs/reference/

# --- Working-memory entry point (local-only; the _docs/memory/* it indexes ARE tracked) ---
# Anchored path so it ignores ONLY this file, never the tracked root CLAUDE.md
_docs/CLAUDE.md

# --- Tooling local do Codex/agents ---
# Configuracoes locais podem conter caminhos absolutos deste computador.
.agents/
.codex/

# --- Arquivos de importacao ja expandidos no repo ---
Retirement_Presentations.zip

# ==============================================================================
# .gitignore for Academic Claude Code Projects
# ==============================================================================

# LaTeX build artifacts
*.aux
*.bbl
*.blg
*.fdb_latexmk
*.fls
*.log
*.nav
*.out
*.snm
*.toc
*.vrb
*.synctex.gz
*.run.xml
*-blx.bib

# Compiled PDFs (uncomment to track specific PDFs)
# *.pdf

# Python
__pycache__/
*.pyc
*.pyo

# R
.Rproj.user/
.Rhistory
.RData
.Rdata

# OS files
.DS_Store
Thumbs.db

# Claude Code local files (not shared across machines)
.claude/settings.local.json
.claude/state/
CLAUDE.local.md

# IDE
# .vscode/settings.json ships in the template (carries shipped Claude Code permission-mode
# recommendations — see TROUBLESHOOTING.md "Permissions / bypass / statusline" for the typo
# fix forkers need). Other .vscode/ content is developer-machine-specific.
.vscode/*
!.vscode/settings.json
.idea/
*.swp
*.swo
*~

# Quarto rendering artifacts
.quarto/

# quality_reports/ — per-project session logs, plans, specs, merges.
# The directory structure ships in the template (via .gitkeep), but the
# content is PROJECT-INTERNAL and shouldn't be inherited by forks.
quality_reports/plans/*
quality_reports/specs/*
quality_reports/session_logs/*
quality_reports/merges/*
quality_reports/decisions/*
quality_reports/checkpoints/*
quality_reports/preregistrations/*
!quality_reports/plans/.gitkeep
!quality_reports/specs/.gitkeep
!quality_reports/session_logs/.gitkeep
!quality_reports/merges/.gitkeep
!quality_reports/decisions/.gitkeep
!quality_reports/checkpoints/.gitkeep
!quality_reports/preregistrations/.gitkeep

# R analysis outputs (generated artifacts; keep scripts, ignore outputs)
scripts/R/_outputs/

# Output artifacts — uncomment lines below based on your preference
# *.rds
# output/**/*.rds

# Stray R default plot device output
Rplots.pdf
