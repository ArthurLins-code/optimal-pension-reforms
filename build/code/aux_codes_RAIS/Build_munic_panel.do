**************************
******* Sections *********
**************************
* I. Public sector jobs
* II. Public sector health and education jobs
* III. Worker's characteristics
* IV. Jobs per sector
* V. Merge 1
* VI. Total number of establishments
* VII. Establishments per sector
* VIII. Merge 2
* IX. Append
**************************

clear all
cap log close
set more off
set seed 12345

set rmsg on

global FIRST_YEAR 1985
global LAST_YEAR  2024
global SECOND_YEAR = ${FIRST_YEAR} + 1
global REGIONS = "centrooeste norte nordeste sul sp mgrjes"

local FIRST_YEAR  ${FIRST_YEAR}
local SECOND_YEAR ${SECOND_YEAR}
local LAST_YEAR   ${LAST_YEAR}
local REGIONS     ${REGIONS}

foreach year of numlist `FIRST_YEAR'(1)`LAST_YEAR' {
foreach region of `REGIONS' {
    
	
	********************************
	* I. Public sector jobs
	********************************

	use "U:\Desktop\RA_RAIS\RAIS\data\contract_level\\`year'\\`year'`region'.dta", clear
	
	* Generating types of establishment
	
	gen public =	inlist(legal_nature, 1015, 1023, 1031, 1040, 1058, 1066, 1074, 1082, 1104, 1112) | inlist(legal_nature, 1120, 1139, 1147, 1155, 1163, 1171, 1180, 1198, 1210, 1228) | inlist(legal_nature, 1236, 1244, 1252, 1260, 1279, 1287, 1295, 1309, 1317, 1325) | inlist(legal_nature, 1333, 1341)
	la var public "Public"
		
	gen public_federal = inlist(legal_nature, 1015, 1040, 1074, 1104, 1139, 1163, 1252, 1287, 1317, 1341)
	la var public_federal "Public Federal"
		
	gen public_state = inlist(legal_nature, 1023, 1058, 1082, 1112, 1147, 1171, 1236, 1260, 1295, 1325)
	la var public_state "Public State"
		
	gen public_municipal = inlist(legal_nature, 1031, 1066, 1120, 1155, 1180, 1244, 1279, 1309, 1333)
	la var public_municipal "Public Municipal"
		
	gen public_exec = inlist(legal_nature, 1015, 1023, 1031)
	la var public_exec "Public Executive"
		
	gen public_leg = inlist(legal_nature, 1040, 1058, 1066)
	la var public_leg "Public Legislative"
		
	gen public_jud = inlist(legal_nature, 1074, 1082, 1120)
	la var public_jud "Public Judiciary"
		
	gen company = inlist(legal_nature, 2011, 2038, 2046, 2054, 2062, 2070, 2089, 2097, 2127, 2135) | inlist(legal_nature, 2143, 2151, 2160, 2178, 2194, 2216, 2224, 2232, 2240, 2259) | inlist(legal_nature, 2267, 2275, 2283, 2291, 2305, 2313, 2321, 2330)
	la var company "Company"
		
	gen company_public = inlist(legal_nature, 2011)
	la var company_public "Public Company"
		
	gen nonprofit =	inlist(legal_nature, 3034, 3069, 3077, 3085, 3107, 3115, 3131, 3204, 3212, 3220) | inlist(legal_nature, 3239, 3247, 3255, 3263, 3271, 3280, 3298, 3301, 3310, 3999)
	la var nonprofit "Non-Profit"
	
	gen n_jobs = 1
	
	gen n_jobs_with_CBO = (occupation94 != "" | occupation02 != "")
	
	gen n_jobs_WC = [ocup_cat == 1 | ocup_cat == 2 | ocup_cat == 3 | ocup_cat == 4]
	gen n_jobs_BC = [ocup_cat = 5]
		
	preserve 
	gcollapse (sum) n_jobs* avg_w_nom avg_w_real, by(munic) fast
			
	la var n_jobs "Jobs"
	la var n_jobs_with_CBO "Jobs with Non-Null CBO"
	la var n_jobs_WC "White-Collar Jobs"
	la var n_jobs_BC "Blue-Collar Jobs"
	la var avg_w_nom "Wage (R$)"
	la var avg_w_real "Wage (R$ `LAST_WAGE')"
			
	tempfile munic_`year'_`region'
	save `munic_`year'_`region''
			
	restore
	preserve
			
	gcollapse (sum) n_jobs avg_w_nom avg_w_real, by(munic public public_federal public_state public_municipal public_exec public_leg public_jud company nonprofit) fast
			
	gen     x = ""
	replace x = "pub_fed_exec" if public_federal == 1 & public_exec == 1
	replace x = "pub_fed_leg" if public_federal == 1 & public_leg == 1
	replace x = "pub_fed_jud" if public_federal == 1 & public_jud == 1
	replace x = "pub_stt_exec" if public_state == 1 & public_exec == 1
	replace x = "pub_stt_leg" if public_state == 1 & public_leg == 1
	replace x = "pub_stt_jud" if public_state == 1 & public_jud == 1
	replace x = "pub_mun_exec" if public_municipal == 1 & public_exec == 1
	replace x = "pub_mun_leg" if public_municipal == 1 & public_leg == 1
	replace x = "pub_mun_jud" if public_municipal == 1 & public_jud == 1
	replace x = "priv" if company == 1
	replace x = "np" if nonprofit == 1
			
	keep if x != ""
	drop public* company nonprofit
			
	ren n_jobs n_jobs_
	ren avg_w_nom avg_w_nom_
	ren avg_w_real avg_w_real_
	reshape wide n_jobs_ avg_w_nom_ avg_w_real_, i(munic) j(x) string
			
	replace n_jobs_pub_fed_exec	= 0 if n_jobs_pub_fed_exec == .
	replace n_jobs_pub_fed_leg = 0 if n_jobs_pub_fed_leg == .
	replace n_jobs_pub_fed_jud = 0 if n_jobs_pub_fed_jud == .
	replace n_jobs_pub_stt_exec = 0 if n_jobs_pub_stt_exec == .
	replace n_jobs_pub_stt_leg = 0 if n_jobs_pub_stt_leg == .
	replace n_jobs_pub_stt_jud = 0 if n_jobs_pub_stt_jud == .
	replace n_jobs_pub_mun_exec = 0 if n_jobs_pub_mun_exec == .
	replace n_jobs_pub_mun_leg = 0 if n_jobs_pub_mun_leg == .
	replace n_jobs_pub_mun_jud = 0 if n_jobs_pub_mun_jud == .
	replace n_jobs_np = 0 if n_jobs_np == .
	replace n_jobs_priv = 0 if n_jobs_priv == .
			
	la var n_jobs_pub_fed_exec "Federal Executive Public Jobs"
	la var n_jobs_pub_fed_leg "Federal Legislative Public Jobs"
	la var n_jobs_pub_fed_jud "Federal Judicial Public Jobs"
	la var n_jobs_pub_stt_exec "State Executive Public Jobs"
	la var n_jobs_pub_stt_leg "State Legislative Public Jobs"
	la var n_jobs_pub_stt_jud "State Judicial Public Jobs"
	la var n_jobs_pub_mun_exec "Municipal Executive Public Jobs"
	la var n_jobs_pub_mun_leg "Municipal Legislative Public Jobs"
	la var n_jobs_pub_mun_jud "Municipal Judicial Public Jobs"
	la var n_jobs_priv "Private Jobs"
	la var n_jobs_np "Non-Profit Jobs"
		
	la var avg_w_nom_pub_fed_exec "Federal Executive Public Wages (R$)"
	la var avg_w_nom_pub_fed_leg "Federal Legislative Public Wages (R$)"
	la var avg_w_nom_pub_fed_jud "Federal Judiciary Public Wages (R$)"
	la var avg_w_nom_pub_stt_exec "State Executive Public Wages (R$)"
	la var avg_w_nom_pub_stt_leg "State Legislative Public Wages (R$)"
	la var avg_w_nom_pub_stt_jud "State Judiciary Public Wages (R$)"
	la var avg_w_nom_pub_mun_exec "Municipal Executive Public Wages (R$)"
	la var avg_w_nom_pub_mun_leg "Municipal Legislative Public Wages (R$)"
	la var avg_w_nom_pub_mun_jud "Municipal Judiciary Public Wages (R$)"
	la var avg_w_nom_priv "Private Wages (R$)"
	la var avg_w_nom_np "Non-Profit Wages (R$)"
		
	la var avg_w_real_pub_fed_exec "Federal Executive Public Wages (R$ `LAST_YEAR')"
	la var avg_w_real_pub_fed_leg "Federal Legislative Public Wages (R$ `LAST_YEAR')"
	la var avg_w_real_pub_fed_jud "Federal Judiciary Public Wages (R$ `LAST_YEAR')"
	la var avg_w_real_pub_stt_exec "State Executive Public Wages (R$ `LAST_YEAR')"
	la var avg_w_real_pub_stt_leg "State Legislative Public Wages (R$ `LAST_YEAR')"
	la var avg_w_real_pub_stt_jud "State Judiciary Public Wages (R$ `LAST_YEAR')"
	la var avg_w_real_pub_mun_exec "Municipal Executive Public Wages (R$ `LAST_YEAR')"
	la var avg_w_real_pub_mun_leg "Municipal Legislative Public Wages (R$ `LAST_YEAR')"
	la var avg_w_real_pub_mun_jud "Municipal Judiciary Public Wages (R$ `LAST_YEAR')"
	la var avg_w_real_priv "Private Wages (R$ `LAST_YEAR')"
	la var avg_w_real_np "Non-Profit Wages (R$ `LAST_YEAR')"
		
	tempfile munic_cat_`year'_`region'
	save `munic_cat_`year'_`region''
			
	restore
		
	use `munic_`year'_`region'', clear
		
	merge 1:1 munic using `munic_cat_`year'_`region'', keep(1 3) nogenerate
			
	*
	
	gen share_jobs_WC = 100 * n_jobs_WC / n_jobs_with_CBO
	la var share_jobs_WC "% Jobs White-Collar"
	
	tempfile munic_jobs
	save `munic_jobs'
	
	
	
	********************************
	* II. Public sector health and education jobs
	********************************
	
	if `year' >= 1995 {
		
		* Job categories (health and education sectors)
		
		use "U:\Desktop\RA_RAIS\RAIS\data\contract_level\\`year'\\`year'`region'.dta", clear
		
		* Generating types of establishment
	
		gen public =	inlist(legal_nature, 1015, 1023, 1031, 1040, 1058, 1066, 1074, 1082, 1104, 1112) | inlist(legal_nature, 1120, 1139, 1147, 1155, 1163, 1171, 1180, 1198, 1210, 1228) | inlist(legal_nature, 1236, 1244, 1252, 1260, 1279, 1287, 1295, 1309, 1317, 1325) | inlist(legal_nature, 1333, 1341)
		la var public "Public"
			
		gen public_federal = inlist(legal_nature, 1015, 1040, 1074, 1104, 1139, 1163, 1252, 1287, 1317, 1341)
		la var public_federal "Public Federal"
			
		gen public_state = inlist(legal_nature, 1023, 1058, 1082, 1112, 1147, 1171, 1236, 1260, 1295, 1325)
		la var public_state "Public State"
			
		gen public_municipal = inlist(legal_nature, 1031, 1066, 1120, 1155, 1180, 1244, 1279, 1309, 1333)
		la var public_municipal "Public Municipal"
			
		gen public_exec = inlist(legal_nature, 1015, 1023, 1031)
		la var public_exec "Public Executive"
			
		gen public_leg = inlist(legal_nature, 1040, 1058, 1066)
		la var public_leg "Public Legislative"
			
		gen public_jud = inlist(legal_nature, 1074, 1082, 1120)
		la var public_jud "Public Judiciary"
			
		gen company =	inlist(legal_nature, 2011, 2038, 2046, 2054, 2062, 2070, 2089, 2097, 2127, 2135) | inlist(legal_nature, 2143, 2151, 2160, 2178, 2194, 2216, 2224, 2232, 2240, 2259) | inlist(legal_nature, 2267, 2275, 2283, 2291, 2305, 2313, 2321, 2330)
		la var company "Company"
			
		gen company_public = inlist(legal_nature, 2011)
		la var company_public "Public Company"
			
		gen nonprofit =	inlist(legal_nature, 3034, 3069, 3077, 3085, 3107, 3115, 3131, 3204, 3212, 3220) | inlist(legal_nature, 3239, 3247, 3255, 3263, 3271, 3280, 3298, 3301, 3310, 3999)
		la var nonprofit "Non-Profit"
		
		gen n_jobs = 1
		
		gen n_jobs_with_CBO = (occupation94 != "" | occupation02 != "")
		
		gen n_jobs_WC = [ocup_cat == 1 | ocup_cat == 2 | ocup_cat == 3 | ocup_cat == 4]
		gen n_jobs_BC = [ocup_cat = 5]
		
		if `year' <= 2002 {
			
			tostring occupation94, replace force
			replace occupation94 = "0" + occupation94 if length(occupation94) == 4
			ren occupation94 CBO
			
		}
		else {
			
			tostring occupation02, replace force
			ren occupation02 CBO
		
		}
		
		gen n_jobs = 1
		
		gcollapse (sum) n_jobs avg_w_nom avg_w_real, by(munic CBO public public_federal public_state public_municipal public_exec public_leg public_jud company nonprofit) fast
		
		gen     x = ""
		replace x = "pub_fed_exec" if public_federal == 1		& public_exec == 1
		replace x = "pub_fed_leg" if public_federal == 1		& public_leg == 1
		replace x = "pub_fed_jud" if public_federal == 1		& public_jud == 1
		replace x = "pub_stt_exec" if public_state == 1		& public_exec == 1
		replace x = "pub_stt_leg" if public_state == 1		& public_leg == 1
		replace x = "pub_stt_jud" if public_state == 1		& public_jud == 1
		replace x = "pub_mun_exec" if public_municipal == 1	& public_exec == 1
		replace x = "pub_mun_leg" if public_municipal == 1	& public_leg == 1
		replace x = "pub_mun_jud" if public_municipal == 1	& public_jud == 1
		replace x = "priv" if company == 1
		replace x = "np" if nonprofit == 1
		
		keep if x != ""
		drop public* company nonprofit
		
		ren n_jobs   n_jobs_
		ren avg_w_nom	avg_w_nom_
		ren avg_w_real avg_w_real_
		reshape wide n_jobs_ avg_w_nom_ avg_w_real_, i(munic CBO) j(x) string
		
		gen aux_ocup = ""
		if `year' <= 2002 {
			replace aux_ocup = "_educ" if real(substr(CBO, 1, 3)) >= 131 & real(substr(CBO, 1, 3)) <= 149
			replace aux_ocup = "_health" if real(substr(CBO, 1, 3)) >= 61 & real(substr(CBO, 1, 3)) <= 79
		}
		else {
			replace aux_ocup = "_educ" if real(substr(CBO, 1, 3)) >= 231 & real(substr(CBO, 1, 3)) <= 239
			replace aux_ocup = "_health" if real(substr(CBO, 1, 3)) >= 221 & real(substr(CBO, 1, 3)) <= 226
		}
		*
		
		drop CBO
		keep if aux_ocup != ""
		gcollapse (sum) n_jobs_* avg_w_*, by(munic aux_ocup) fast
		reshape wide n_jobs_* avg_w_*, i(munic) j(aux_ocup) string
		
		foreach g in educ health {
			
			if "`g'" == "educ" local name Education
			if "`g'" == "health" local name Health
			
			replace n_jobs_pub_fed_exec_`g'	= 0 if n_jobs_pub_fed_exec_`g' == .
			replace n_jobs_pub_fed_leg_`g' = 0 if n_jobs_pub_fed_leg_`g' == .
			replace n_jobs_pub_fed_jud_`g' = 0 if n_jobs_pub_fed_jud_`g' == .
			replace n_jobs_pub_stt_exec_`g'	= 0 if n_jobs_pub_stt_exec_`g' == .
			replace n_jobs_pub_stt_leg_`g' = 0 if n_jobs_pub_stt_leg_`g' == .
			replace n_jobs_pub_stt_jud_`g' = 0 if n_jobs_pub_stt_jud_`g' == .
			replace n_jobs_pub_mun_exec_`g' = 0 if n_jobs_pub_mun_exec_`g' == .
			replace n_jobs_pub_mun_leg_`g' = 0 if n_jobs_pub_mun_leg_`g' == .
			replace n_jobs_pub_mun_jud_`g' = 0 if n_jobs_pub_mun_jud_`g' == .
			replace n_jobs_np_`g' = 0 if n_jobs_np_`g' == .
			replace n_jobs_priv_`g' = 0 if n_jobs_priv_`g' == .
			
			la var n_jobs_pub_fed_exec_`g' "Federal Executive Public `name' Jobs"
			la var n_jobs_pub_fed_leg_`g' "Federal Legislative Public `name' Jobs"
			la var n_jobs_pub_fed_jud_`g' "Federal Judicial Public `name' Jobs"
			la var n_jobs_pub_stt_exec_`g' "State Executive Public `name' Jobs"
			la var n_jobs_pub_stt_leg_`g' "State Legislative Public `name' Jobs"
			la var n_jobs_pub_stt_jud_`g' "State Judicial Public `name' Jobs"
			la var n_jobs_pub_mun_exec_`g' "Municipal Executive Public `name' Jobs"
			la var n_jobs_pub_mun_leg_`g' "Municipal Legislative Public `name' Jobs"
			la var n_jobs_pub_mun_jud_`g' "Municipal Judicial Public `name' Jobs"
			la var n_jobs_priv_`g' "Private `name' Jobs"
			la var n_jobs_np_`g' "Non-Profit `name' Jobs"
			
			la var avg_w_nom_pub_fed_exec_`g' "Federal Executive Public `name' Wages (R$)"
			la var avg_w_nom_pub_fed_leg_`g' "Federal Legislative Public `name' Wages (R$)"
			la var avg_w_nom_pub_fed_jud_`g' "Federal Judiciary Public `name' Wages (R$)"
			la var avg_w_nom_pub_stt_exec_`g' "State Executive Public `name' Wages (R$)"
			la var avg_w_nom_pub_stt_leg_`g' "State Legislative Public `name' Wages (R$)"
			la var avg_w_nom_pub_stt_jud_`g' "State Judiciary Public `name' Wages (R$)"
			la var avg_w_nom_pub_mun_exec_`g' "Municipal Executive Public `name' Wages (R$)"
			la var avg_w_nom_pub_mun_leg_`g' "Municipal Legislative Public `name' Wages (R$)"
			la var avg_w_nom_pub_mun_jud_`g' "Municipal Judiciary Public `name' Wages (R$)"
			la var avg_w_nom_priv_`g' "Private `name' Wages (R$)"
			la var avg_w_nom_np_`g' "Non-Profit `name' Wages (R$)"
			
			la var avg_w_real_pub_fed_exec_`g' "Federal Executive Public `name' Wages (R$ `LAST_YEAR')"
			la var avg_w_real_pub_fed_leg_`g' "Federal Legislative Public `name' Wages (R$ `LAST_YEAR')"
			la var avg_w_real_pub_fed_jud_`g' "Federal Judiciary Public `name' Wages (R$ `LAST_YEAR')"
			la var avg_w_real_pub_stt_exec_`g' "State Executive Public `name' Wages (R$ `LAST_YEAR')"
			la var avg_w_real_pub_stt_leg_`g' "State Legislative Public `name' Wages (R$ `LAST_YEAR')"
			la var avg_w_real_pub_stt_jud_`g' "State Judiciary Public `name' Wages (R$ `LAST_YEAR')"
			la var avg_w_real_pub_mun_exec_`g' "Municipal Executive Public `name' Wages (R$ `LAST_YEAR')"
			la var avg_w_real_pub_mun_leg_`g' "Municipal Legislative Public `name' Wages (R$ `LAST_YEAR')"
			la var avg_w_real_pub_mun_jud_`g' "Municipal Judiciary Public `name' Wages (R$ `LAST_YEAR')"
			la var avg_w_real_priv_`g' "Private `name' Wages (R$ `LAST_YEAR')"
			la var avg_w_real_np_`g' "Non-Profit `name' Wages (R$ `LAST_YEAR')"
			
		}
		
		tempfile munic_jobs_social
		save `munic_jobs_social'
		
		
		******************************
		* III. Worker's characteristics
		******************************
		
		use "U:\Desktop\RA_RAIS\RAIS\data\contract_level\\`year'\\`year'`region'.dta", clear
		
		* Generating types of establishment
	
		gen public =	inlist(legal_nature, 1015, 1023, 1031, 1040, 1058, 1066, 1074, 1082, 1104, 1112) | inlist(legal_nature, 1120, 1139, 1147, 1155, 1163, 1171, 1180, 1198, 1210, 1228) | inlist(legal_nature, 1236, 1244, 1252, 1260, 1279, 1287, 1295, 1309, 1317, 1325) | inlist(legal_nature, 1333, 1341)
		la var public "Public"
			
		gen public_federal = inlist(legal_nature, 1015, 1040, 1074, 1104, 1139, 1163, 1252, 1287, 1317, 1341)
		la var public_federal "Public Federal"
			
		gen public_state = inlist(legal_nature, 1023, 1058, 1082, 1112, 1147, 1171, 1236, 1260, 1295, 1325)
		la var public_state "Public State"
			
		gen public_municipal = inlist(legal_nature, 1031, 1066, 1120, 1155, 1180, 1244, 1279, 1309, 1333)
		la var public_municipal "Public Municipal"
			
		gen public_exec = inlist(legal_nature, 1015, 1023, 1031)
		la var public_exec "Public Executive"
			
		gen public_leg = inlist(legal_nature, 1040, 1058, 1066)
		la var public_leg "Public Legislative"
			
		gen public_jud = inlist(legal_nature, 1074, 1082, 1120)
		la var public_jud "Public Judiciary"
			
		gen company =	inlist(legal_nature, 2011, 2038, 2046, 2054, 2062, 2070, 2089, 2097, 2127, 2135) | inlist(legal_nature, 2143, 2151, 2160, 2178, 2194, 2216, 2224, 2232, 2240, 2259) | inlist(legal_nature, 2267, 2275, 2283, 2291, 2305, 2313, 2321, 2330)
		la var company "Company"
			
		gen company_public = inlist(legal_nature, 2011)
		la var company_public "Public Company"
			
		gen nonprofit =	inlist(legal_nature, 3034, 3069, 3077, 3085, 3107, 3115, 3131, 3204, 3212, 3220) | inlist(legal_nature, 3239, 3247, 3255, 3263, 3271, 3280, 3298, 3301, 3310, 3999)
		la var nonprofit "Non-Profit"
		
		gen n_jobs = 1
		
		gen n_jobs_with_CBO = (occupation94 != "" | occupation02 != "")
		
		gen n_jobs_WC = [ocup_cat == 1 | ocup_cat == 2 | ocup_cat == 3 | ocup_cat == 4]
		gen n_jobs_BC = [ocup_cat = 5]
		
		keep if public_municipal == 1 
		
		gcollapse (max) education, by(enc_id_worker munic) fast
		
		gen n_workers_pub_mun         = (schooling != .)
		gen n_workers_pub_mun_college = (schooling >= 9)
		
		gcollapse (sum) n_workers*, by(munic)
		
		gen share_workers_pub_mun_college = 100 * n_workers_pub_mun_college / n_workers_pub_mun
		la var share_workers_pub_mun_college "% College"
		
		tempfile munic_share_college
		save `munic_share_college'
	
	}
	
	
	********************************
	* IV. Jobs per sector
	********************************
	
	if `year' >= 1995 {
			
		use "U:\Desktop\RA_RAIS\RAIS\data\contract_level\\`year'\\`year'`region'.dta", clear
			
		gen n_jobs_agric = (sector == 1) if sector != .
		gen n_jobs_OMM = (sector == 2) if sector != .
		gen n_jobs_manuf = (sector == 3) if sector != .
		gen n_jobs_constr = (sector == 4) if sector != .
		gen n_jobs_retail = (sector == 5) if sector != .
		gen n_jobs_other_serv = (sector == 6) if sector != .
		gen n_jobs_gov = (sector == 7) if sector != .
		gen n_jobs_IO = (sector == 8) if sector != .
			
		gen avg_w_nom_agric = avg_w_nom * (sector == 1) if sector != .
		gen avg_w_nom_OMM = avg_w_nom * (sector == 2) if sector != .
		gen avg_w_nom_manuf = avg_w_nom * (sector == 3) if sector != .
		gen avg_w_nom_constr = avg_w_nom * (sector == 4) if sector != .
		gen avg_w_nom_retail	= avg_w_nom * (sector == 5) if sector != .
		gen avg_w_nom_other_serv = avg_w_nom * (sector == 6) if sector != .
		gen avg_w_nom_gov = avg_w_nom * (sector == 7) if sector != .
		gen avg_w_nom_IO = avg_w_nom * (sector == 8) if sector != .
		
		gen avg_w_real_agric = avg_w_real * (sector == 1) if sector != .
		gen avg_w_real_OMM = avg_w_real * (sector == 2) if sector != .
		gen avg_w_real_manuf = avg_w_real * (sector == 3) if sector != .
		gen avg_w_real_constr = avg_w_real * (sector == 4) if sector != .
		gen avg_w_real_retail = avg_w_real * (sector == 5) if sector != .
		gen avg_w_real_other_serv = avg_w_real * (sector == 6) if sector != .
		gen avg_w_real_gov = avg_w_real * (sector == 7) if sector != .
		gen avg_w_real_IO = avg_w_real * (sector == 8) if sector != .
			
		gcollapse (sum) n_jobs_* wage_*, by(munic) fast
			
		la var n_jobs_agric	"Jobs: Agriculture"
		la var n_jobs_OMM "Jobs: Oil, Mining and Metals"
		la var n_jobs_manuf "Jobs: Manufacturing"
		la var n_jobs_constr "Jobs: Construction"
		la var n_jobs_retail "Jobs: Retail"
		la var n_jobs_other_serv "Jobs: Other Services"
		la var n_jobs_gov "Jobs: Goverment"
		la var n_jobs_IO "Jobs: Information and Communication"
		
		la var wage_agric "Wages (R$): Agriculture"
		la var wage_OMM	"Wages (R$): Oil, Mining and Metals"
		la var wage_manuf "Wages (R$): Manufacturing"
		la var wage_constr "Wages (R$): Construction"
		la var wage_retail "Wages (R$): Retail"
		la var wage_other_serv "Wages (R$): Other Services"
		la var wage_gov "Wages (R$): Goverment"
		la var wage_IO "Wages (R$): Information and Communication"
		
		la var wage_def_agric "Wages (R$ `LAST_YEAR'): Agriculture"
		la var wage_def_OMM "Wages (R$ `LAST_YEAR'): Oil, Mining and Metals"
		la var wage_def_manuf "Wages (R$ `LAST_YEAR'): Manufacturing"
		la var wage_def_constr "Wages (R$ `LAST_YEAR'): Construction"
		la var wage_def_retail "Wages (R$ `LAST_YEAR'): Retail"
		la var wage_def_other_serv "Wages (R$ `LAST_YEAR'): Other Services"
		la var wage_def_gov "Wages (R$ `LAST_YEAR'): Goverment"
		la var wage_def_IO "Wages (R$ `LAST_YEAR'): Information and Communication"
			
		tempfile munic_jobs_sector
		save `munic_jobs_sector'
	}
		
	********************************
	* V. Merge 1
	********************************
		
		use `munic_jobs', clear
		
		if `year' >= 1995 {
			merge 1:1 munic using `munic_jobs_social', nogenerate
			merge 1:1 munic using `munic_share_college', nogenerate
			merge 1:1 munic using `munic_jobs_sector', nogenerate
			merge 1:1 munic using `munic_estab_sector', nogenerate
		}
		
		gen year = `year'
		la var year "Year"
		
		save "TEMPORARY FILE PATH/munic_`year'.dta", replace	
		
	}
	
	
	
	********************************
	* VI. Total number of establishments
	********************************
	
	use "U:\Desktop\RA_RAIS\RAIS\data\firm_level\\`year'.dta", clear
		
	gen n_estab = 1
		
	gcollapse (sum) n_estab, by(munic) fast
		
	la var n_estab "Establishments"
		
	tempfile munic_estab
	save `munic_estab'
	
	
	
	********************************
	* VII. Establishments per sector
	********************************
			
	use "U:\Desktop\RA_RAIS\RAIS\data\firm_level\\`year'.dta", clear
			
	gen n_estab_agric = (sector == 1) if sector != .
	gen n_estab_OMM = (sector == 2) if sector != .
	gen n_estab_manuf = (sector == 3) if sector != .
	gen n_estab_constr = (sector == 4) if sector != .
	gen n_estab_retail = (sector == 5) if sector != .
	gen n_estab_other_serv = (sector == 6) if sector != .
	gen n_estab_gov = (sector == 7) if sector != .
	gen n_estab_IO = (sector == 8) if sector != .
		
	gen n_estab_pub = (legal_type == 1) if legal_nature != .
	gen n_estab_priv = (legal_type == 2) if legal_nature != .
	gen n_estab_np = (legal_type == 3) if legal_nature != .
		
	gcollapse (sum) n_estab_*, by(munic) fast
		
	la var n_estab_agric "Establishments: Agriculture"
	la var n_estab_OMM "Establishments: Oil, Mining and Metals"
	la var n_estab_manuf "Establishments: Manufacuring"
	la var n_estab_constr "Establishments: Construction"
	la var n_estab_retail "Establishments: Retail"
	la var n_estab_other_serv "Establishments: Other Services"
	la var n_estab_gov "Establishments: Goverment"
	la var n_estab_IO "Establishments: Information and Communication"
			
	la var n_estab_pub			"Establishments: Public"
	la var n_estab_priv			"Establishments: Private"
	la var n_estab_np			"Establishments: Nonprofit"
			
	tempfile munic_estab_sector
	save `munic_estab_sector'
	
	
	
	********************************
	* VIII. Merge 2
	********************************
	
	use "TEMPORARY FILE PATH/munic_`year'.dta", clear
	
	merge 1:1 munic using `munic_estab', nogenerate
		
		if `year' >= 1995 {
			merge 1:1 munic using `munic_jobs_social', nogenerate
			merge 1:1 munic using `munic_share_college', nogenerate
			merge 1:1 munic using `munic_jobs_sector', nogenerate
			merge 1:1 munic using `munic_estab_sector', nogenerate
		}
		
	save "TEMPORARY FILE PATH/munic_`year'.dta", replace	
			
	
	
	}

	

