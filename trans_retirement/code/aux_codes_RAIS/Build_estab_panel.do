**************************
******* Sections *********
**************************
* I. Calculating quarterly contracts
* II. Agregating by establishment
* III. Formatting
**************************

clear all
cap log close
set more off
set seed 12345

set rmsg on

global FIRST_YEAR 1985
global LAST_YEAR  2024
global SECOND_YEAR = ${FIRST_YEAR} + 1
global REGIONS = "centrooeste norte nordeste sul sp mgrjes"

local FIRST_YEAR  ${FIRST_YEAR}
local SECOND_YEAR ${SECOND_YEAR}
local LAST_YEAR   ${LAST_YEAR}
local REGIONS     ${REGIONS}



********************************
* I. Calculating quarterly contracts
********************************

foreach year of numlist `FIRST_YEAR'(1)`LAST_YEAR'{
foreach trimestre in 3 6 9 12 {
foreach region of `REGIONS' {
display "*********************************************"
display `year'
display `trimestre'
display `region'
display "*********************************************"
	
*Opening the datasets
use "U:\Desktop\RA_RAIS\RAIS\data\contract_level\\`year'\\`year'`region'.dta", clear

* Droping irregular ids
drop if enc_id_worker == "00000000000"

* Droping duplicates
duplicates drop

* Generating variables
gen year = `year'
gen trimestre = `trimestre'

* Keeping only certain contracts (in this case, open-ended CLT contracts)
keep if inlist(contr_type, 10, 15, 20, 25)

* Keeping only workers with positive earnings
keep if avg_w_real > 0

* Keeping only certain firms (in this case, private sector firms)
keep if inlist(legal_nature, 2046, 2054, 2062, 2070, 2076, 2089, 2097, 2100, 2119) | inlist(legal_nature, 2127, 2135, 2143, 2151, 2160, 2178, 2194, 2208, 2216) | inlist(legal_nature, 2224, 2232, 2240, 2259, 2267, 2275, 2283, 2291, 2292) | inlist(legal_nature, 2305, 2313, 2321, 2330)

* Droping people hired before a certain year (in this case, 1991)
drop if hire_year < 1991 | hire_year == . 

* Transforming the format of some variables to facilitate the collapse
destring enc_id_firm cbo1994 sector, replace dpcomma force
format enc_id_firm %16.0g
format cbo1994 %16.0g
format sector %16.0g

* Keeping individuals that:
* (1) Were hired before or during the quarter and were separated during or after the quarter;
* (2) Were hired before or during the quarter and were not separated during the year; 
* (3) Were hired before the year and separated during or after the quarter;
* (4) Were hired before the year and were not separated during the year.
keep if (hire_month<=`trimestre' & hire_year==`year' & (sep_month>`trimestre'-3) | hire_month<=`trimestre' & hire_year==`year' & empl_31dec==1 | hire_year<`year' & (sep_month>`trimestre'-3) | hire_year<`year' & empl_31dec==1)

* Creating some hiring and separation variables
g n_total_contracts=1
g hirings=[hire_month==`trimestre' & hire_year==`year' | (hire_month==`trimestre'-1) & hire_year==`year' | (hire_month==`trimestre'-2) & hire_year==`year']
g separations=[sep_month==`trimestre' | (sep_month==`trimestre'-1) | ((sep_month==`trimestre'-2))]
g voluntary_separations=[reas_sep==21 & separations==1]
g separations_no_duecause=[reas_sep==11 & separations==1]
g contract_end=[reas_sep==12 & separations==1]

* Creating the number of active contracts at the end of the quarter
g n_act_contracts=0
replace n_act_contracts=1 if hire_month<=`trimestre' & hire_year==`year' & (sep_month>`trimestre' | empl_31dec==1)
replace n_act_contracts=1 if hire_year<`year' & (sep_month>`trimestre' | empl_31dec==1)

*Ordering
sort enc_cnpj_cei



******************************************
* II. Agregating by establishment
******************************************

collapse (max) enc_id_firm (firstnm) munic sector (mean) year trimestre age schooling hours gender (sum) n_act_contracts n_total_contracts separations hirings separations_no_duecause voluntary_separations contract_end, by(enc_cnpj_cei)

*Salving and appending
if year==`FIRST_YEAR' & trimestre==3 & region=="centrooeste" {
	save "INSERT THE PATH OF THE FILE YOU WANT TO SAVE", replace
} 
else {
	save "INSERT THE PATH OF THE AUXILIARY FILE YOU WANT TO SAVE", replace
	use "INSERT THE PATH OF THE FILE YOU WANT TO SAVE", clear
	append using "INSERT THE PATH OF THE AUXILIARY FILE YOU WANT TO SAVE"
	save "INSERT THE PATH OF THE FILE YOU WANT TO SAVE", replace
	erase "INSERT THE PATH OF THE AUXILIARY FILE YOU WANT TO SAVE"
}


}
}
}



******************************************
* III. Formatting
******************************************

* Calling and ordering the data
use "INSERT THE PATH OF THE FILE YOU WANT TO SAVE", clear
sort enc_cnpj_cei year trimestre

* Creating time series ids
destring enc_cnpj_cei, generate(cnpj_num) force
format cnpj_num %16.0g
gen ym = yq(year, trimestre/3)
format ym %tq
xtset cnpj_num ym

* Forcing a balanced panel
tsfill, full
replace year = year(dofq(ym))
replace trimestre = quarter(dofq(ym))

* Filling in the values for some variables
foreach v of varlist enc_id_firm munic sector {
	by cnpj_num: replace `v' = `v'[_n-1] if missing(`v')
}
gsort cnpj_num -ym
foreach v of varlist enc_id_firm munic sector {
	by cnpj_num: replace `v' = `v'[_n-1] if missing(`v')
}
sort cnpj_num ym
foreach v of varlist separations hirings voluntary_separations separations_no_duecause contract_end n_act_contracts n_total_contracts hours age gender schooling {
	replace `v' = 0 if missing(`v')
}

* Creating the firm's first appearance variable
by cnpj_num: gen first_obs = [(n_act_contracts != 0) & (sum(n_act_contracts != 0) == 1)]
gen enter = [n_act_contracts != 0 & n_act_contracts == hirings & first_obs == 1 & year != `FIRST_YEAR' & trimestre != 3]

* Creating the firm's last appearance variable
gsort cnpj_num -ym
by cnpj_num: gen last_nonzero = [(n_total_contracts != 0) & (sum(n_total_contracts != 0) == 1)]
gen close = [n_total_contracts != 0 & n_act_contracts == 0 & last_nonzero == 1 & year != `LAST_YEAR' & trimestre != 12]
sort cnpj_num ym

* Deleting the firms that only appear in some years, without closing or opening
by cnpj_num: egen drop_flag = max(first_obs == 1 & enter == 0 & year != `FIRST_YEAR' & trimestre != 3)
drop if drop_flag == 1
drop drop_flag
by cnpj_num: egen drop_flag = max(last_nonzero == 1 & close == 0 & year != `LAST_YEAR' & trimestre != 12)
drop if drop_flag == 1
drop drop_flag

* Deleting the observations before the first and after the last appearance of the firms
by cnpj_num: gen saiu = 1 if close[_n-1] == 1
by cnpj_num: replace saiu = 1 if saiu[_n-1] == 1
drop if saiu == 1
gsort cnpj_num -ym
by cnpj_num: gen entrou = 1 if enter[_n-1] == 1
by cnpj_num: replace entrou = 1 if entrou[_n-1] == 1
drop if entrou == 1
sort cnpj_num ym

* Dropping unecessary variables
drop first_obs last_nonzero saiu entrou

*Saving final dataset
xtset cnpj_num ym
save "INSERT THE PATH OF THE FILE YOU WANT TO SAVE", replace
